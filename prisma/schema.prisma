datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  tema      String   @default("dark")
  activo    Boolean  @default(true)
  sessionVersion Int @default(0)
  createdAt DateTime @default(now())
}

model AuthRateLimit {
  key          String   @id
  count        Int      @default(0)
  windowStart  DateTime @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime @updatedAt

  @@index([updatedAt])
}

model Cliente {
  id               String        @id @default(cuid())
  nombre           String
  empresa          String?
  nit              String?
  direccion        String?
  contactoNombre   String
  telefono         String
  email            String?
  ciudad           String
  departamento     String
  pais             String        @default("Colombia")
  tipoNegocio      String
  estado           String        @default("COTIZADO")
  socioResponsable String
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  interacciones    Interaccion[]
  monitoreos       Monitoreo[]
  cotizaciones     Cotizacion[]
  transacciones    Transaccion[]
  tareas           Tarea[]
  documentos       Documento[]
  facturas         Factura[]
  movimientosInventario MovimientoStock[]

  @@index([estado])
  @@index([createdAt])
}

model Interaccion {
  id            String    @id @default(cuid())
  clienteId     String
  cliente       Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo          String
  descripcion   String
  fecha         DateTime
  socio         String
  proximaAccion String?
  fechaProxima  DateTime?
  createdAt     DateTime  @default(now())

  @@index([clienteId, fecha])
}

model Cotizacion {
  id               String          @id @default(cuid())
  numero           String          @unique
  clienteId        String
  cliente          Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  fechaEmision     DateTime
  fechaVencimiento DateTime?
  estado           String          @default("BORRADOR")
  socio            String
  descuento        Float           @default(0)
  iva              Float           @default(0)
  moneda           String          @default("COP")
  vendedor         String?
  formaPago        String?
  tiempoEntrega    String?
  garantia         String?
  condiciones      String?
  aceptacionCliente String?
  legalJson        String?
  observaciones    String?
  notasInternas    String?
  items            CotizacionItem[]
  documentos       Documento[]
  facturas         Factura[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([clienteId, fechaEmision])
  @@index([estado])
}

model CotizacionItem {
  id           String     @id @default(cuid())
  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  descripcion  String
  nombre       String?
  descripcionLarga String?
  sku          String?
  unidad       String       @default("unidad")
  cantidad     Float
  precioUnit   Float
  descuento    Float        @default(0)
  ivaTipo      String       @default("NO_RESPONSABLE")
  ivaPorcentaje Float       @default(0)
  baseGravable Float        @default(0)
  ivaMonto     Float        @default(0)
  total        Float        @default(0)
  subtotal     Float
  orden        Int        @default(0)
}

model Factura {
  id               String        @id @default(cuid())
  numero           String        @unique
  clienteId        String
  cliente          Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  cotizacionId     String?
  cotizacion       Cotizacion?   @relation(fields: [cotizacionId], references: [id], onDelete: SetNull)
  fechaEmision     DateTime
  fechaVencimiento DateTime?
  fechaPago        DateTime?
  estado           String        @default("BORRADOR")
  socio            String
  descuento        Float         @default(0)
  iva              Float         @default(0)
  moneda           String        @default("COP")
  vendedor         String?
  formaPago        String?
  garantia         String?
  condiciones      String?
  legalJson        String?
  observaciones    String?
  notasInternas    String?
  metodoPago       String?
  items            FacturaItem[]
  documentos       Documento[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([clienteId, fechaEmision])
  @@index([cotizacionId])
  @@index([estado])
}

model FacturaItem {
  id          String   @id @default(cuid())
  facturaId   String
  factura     Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  descripcion String
  nombre      String?
  descripcionLarga String?
  sku         String?
  unidad      String   @default("unidad")
  cantidad    Float
  precioUnit  Float
  descuento   Float    @default(0)
  ivaTipo     String   @default("NO_RESPONSABLE")
  ivaPorcentaje Float  @default(0)
  baseGravable Float   @default(0)
  ivaMonto    Float    @default(0)
  total       Float    @default(0)
  subtotal    Float
  orden       Int      @default(0)
}

model Monitoreo {
  id                      String          @id @default(cuid())
  clienteId               String
  cliente                 Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  kitId                   String?
  fechaInstalacion        DateTime
  frecuenciaMantenimiento Int
  ultimoMantenimiento     DateTime?
  proximoMantenimiento    DateTime?
  estado                  String          @default("ACTIVO")
  observaciones           String?
  mantenimientos          Mantenimiento[]
  documentos              Documento[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([clienteId])
  @@index([proximoMantenimiento])
}

model Mantenimiento {
  id            String     @id @default(cuid())
  monitoreoId   String
  monitoreo     Monitoreo  @relation(fields: [monitoreoId], references: [id], onDelete: Cascade)
  fecha         DateTime
  socio         String
  descripcion   String
  observaciones String?
  createdAt     DateTime   @default(now())

  @@index([monitoreoId, fecha])
}

model InventarioItem {
  id            String            @id @default(cuid())
  nombre        String
  categoria     String
  unidad        String
  stockActual   Float             @default(0)
  stockMinimo   Float             @default(0)
  costoUnitario Float             @default(0)
  proveedor     String?
  notas         String?
  movimientos   MovimientoStock[]
  createdAt     DateTime          @default(now())
}

model MovimientoStock {
  id          String         @id @default(cuid())
  itemId      String
  item        InventarioItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tipo        String
  cantidad    Float
  costo       Float?
  proveedor   String?
  clienteId   String?
  cliente     Cliente?       @relation(fields: [clienteId], references: [id])
  descripcion String
  socio       String
  fecha       DateTime
  createdAt   DateTime       @default(now())

  @@index([itemId, fecha])
  @@index([clienteId])
}

model Transaccion {
  id           String    @id @default(cuid())
  tipo         String
  categoria    String
  descripcion  String
  monto        Float
  socio        String
  metodoPago   String?
  clienteId    String?
  cliente      Cliente?  @relation(fields: [clienteId], references: [id])
  cotizacionId String?
  fecha        DateTime
  createdAt    DateTime  @default(now())

  @@index([tipo, fecha])
  @@index([clienteId])
}

model Tarea {
  id          String    @id @default(cuid())
  titulo      String
  descripcion String?
  asignadoA   String
  prioridad   String
  fechaLimite DateTime?
  estado      String    @default("PENDIENTE")
  clienteId   String?
  cliente     Cliente?  @relation(fields: [clienteId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([estado, fechaLimite])
  @@index([clienteId])
}

model Documento {
  id             String      @id @default(cuid())
  nombre         String
  nombreArchivo  String?
  tipo           String
  descripcion    String?
  rutaArchivo    String
  mimeType       String
  tamañoBytes    Int
  clienteId      String?
  cliente        Cliente?    @relation(fields: [clienteId], references: [id])
  cotizacionId   String?
  cotizacion     Cotizacion? @relation(fields: [cotizacionId], references: [id])
  monitoreoId    String?
  monitoreo      Monitoreo?  @relation(fields: [monitoreoId], references: [id])
  facturaId      String?
  factura        Factura?    @relation(fields: [facturaId], references: [id])
  socio          String
  fechaDocumento DateTime?
  tags           String?
  createdAt      DateTime    @default(now())

  @@index([clienteId, createdAt])
  @@index([cotizacionId])
  @@index([facturaId])
  @@index([monitoreoId])
}

model BitacoraEvento {
  id        String   @id @default(cuid())
  socio     String
  modulo    String
  accion    String
  entidadId String?
  detalle   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([modulo])
}

model ConfiguracionComercial {
  id                    String   @id @default("default")
  logoUrl               String   @default("/brand/image2.png")
  colorPrimario         String   @default("#428d73")
  colorSecundario       String   @default("#5c9bc6")
  razonSocial           String   @default("AgroEve")
  nit                   String   @default("1007072083-6")
  direccion             String   @default("")
  ciudad                String   @default("")
  telefono              String   @default("")
  correo                String   @default("agroeve.contacto@gmail.com")
  paginaWeb             String   @default("")
  piePagina             String   @default("Documento generado por el sistema interno de AgroEve.")
  informacionLegal      String   @default("Documento comercial preparado para operacion en Colombia. Integracion DIAN pendiente.")
  informacionBancaria   String   @default("")
  notasAutomaticas      String   @default("")
  garantiaPredeterminada String  @default("")
  ivaPredeterminado     Float    @default(0)
  moneda                String   @default("COP")
  dianJson              String?
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}
